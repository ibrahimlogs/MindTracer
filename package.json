{
  "name": "mindtrace-reasoning-lab",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:education": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node src/data/education/validate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "evaluate:reasoning": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/evaluate-reasoning.ts",
    "evaluate:verification": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/evaluate-verification.ts",
    "evaluate:intervention": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/evaluate-intervention.ts",
    "evaluate:reasoning-delta": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/evaluate-reasoning-delta.ts",
    "evaluate:transfer": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/evaluate-transfer.ts",
    "test:openai:smoke": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/openai-smoke.ts",
    "test:openai:ranking-smoke": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/openai-ranking-smoke.ts",
    "test:openai:verification-smoke": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/openai-verification-smoke.ts",
    "test:openai:intervention-smoke": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/openai-intervention-smoke.ts",
    "test:openai:delta-smoke": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/openai-delta-smoke.ts",
    "test:openai:transfer-smoke": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/openai-transfer-smoke.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/prisma-migrate.ts",
    "prisma:seed": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/seed-education.ts",
    "prisma:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:validate": "pnpm validate:education && pnpm prisma:generate",
    "sessions:cleanup": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-specifier-resolution=node scripts/cleanup-sessions.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-slot": "1.2.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.42.2",
    "lucide-react": "0.468.0",
    "next": "16.2.10",
    "openai": "6.7.0",
    "pg": "8.16.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.66.0",
    "tailwind-merge": "3.4.0",
    "three": "^0.185.1",
    "zod": "4.1.12",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@tailwindcss/postcss": "4.1.17",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.10.1",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/three": "^0.185.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "jsdom": "27.2.0",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.7.1",
    "prisma": "7.8.0",
    "tailwindcss": "4.1.17",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vitest": "4.0.13"
  }
}
