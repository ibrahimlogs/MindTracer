generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  active
  experimental
  archived
}

enum MisconceptionSeverity {
  low
  medium
  high
}

enum SessionMode {
  compare
  learner
  pipeline
  judge
}

enum SessionStatus {
  active
  completed
  abandoned
  expired
}

enum LearningStage {
  problem_presented
  initial_attempt
  reasoning_analysis
  hypothesis_ready
  verification_required
  verification_submitted
  intervention_ready
  intervention_shown
  retry_required
  retry_submitted
  reasoning_delta
  transfer_presented
  transfer_submitted
  session_complete
}

enum AttemptType {
  initial
  retry
  transfer
}

enum AnalysisSource {
  deterministic
  fallback
}

enum VerificationStatus {
  pending
  answered
  skipped
}

model Concept {
  id            String       @id
  familyId      String
  title         String
  description   String
  status        RecordStatus
  sourceVersion String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([familyId])
  @@index([status])
}

model Problem {
  id                String                 @id
  title             String
  conceptFamilyId   String
  difficulty        String
  contentJson       Json
  correctAnswerJson Json
  solutionModelJson Json
  rubricId          String
  status            RecordStatus
  sourceVersion     String
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  misconceptions    ProblemMisconception[]
  sessions          LearningSession[]
  attempts          LearnerAttempt[]
  transfers         TransferAttempt[]

  @@index([conceptFamilyId])
  @@index([rubricId])
  @@index([status])
}

model Misconception {
  id             String                    @id
  title          String
  description    String
  severity       MisconceptionSeverity
  contentJson    Json
  status         RecordStatus
  sourceVersion  String
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  problems       ProblemMisconception[]
  hypotheses     MisconceptionHypothesis[]
  interventions  Intervention[]

  @@index([severity])
  @@index([status])
}

model ProblemMisconception {
  problemId       String
  misconceptionId String
  priority        Int
  createdAt       DateTime      @default(now())
  problem         Problem       @relation(fields: [problemId], references: [id], onDelete: Cascade)
  misconception   Misconception @relation(fields: [misconceptionId], references: [id], onDelete: Cascade)

  @@id([problemId, misconceptionId])
  @@unique([problemId, misconceptionId])
  @@index([misconceptionId])
}

model LearningSession {
  id                     String                    @id @default(cuid())
  publicId               String                    @unique
  mode                   SessionMode
  currentProblemId        String
  currentLearnerKey       String
  currentStage            LearningStage
  status                 SessionStatus
  educationalDataVersion  String
  startedAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  completedAt            DateTime?
  expiresAt              DateTime
  metadataJson           Json
  currentProblem          Problem                   @relation(fields: [currentProblemId], references: [id])
  attempts               LearnerAttempt[]
  hypotheses             MisconceptionHypothesis[]
  verification           VerificationInteraction[]
  interventions          Intervention[]
  transferAttempts       TransferAttempt[]
  report                 ReasoningDeltaReport?
  events                 SessionEvent[]

  @@index([publicId])
  @@index([status])
  @@index([expiresAt])
  @@index([currentStage])
}

model LearnerAttempt {
  id               String             @id @default(cuid())
  sessionId        String
  problemId        String
  attemptType      AttemptType
  answerJson       Json
  explanation      String
  selectedApproach String?
  confidence       String?
  submissionKey    String
  createdAt        DateTime           @default(now())
  session          LearningSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problem          Problem            @relation(fields: [problemId], references: [id])
  analysis         ReasoningAnalysis?
  hypotheses       MisconceptionHypothesis[]

  @@unique([sessionId, submissionKey])
  @@index([sessionId, attemptType])
}

model ReasoningAnalysis {
  id                    String         @id @default(cuid())
  attemptId             String         @unique
  source                AnalysisSource
  extractedEvidenceJson Json
  safeSummaryJson       Json
  promptVersion         String
  modelMetadataJson     Json
  createdAt             DateTime       @default(now())
  attempt               LearnerAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}

model MisconceptionHypothesis {
  id                      String          @id @default(cuid())
  sessionId               String
  attemptId               String
  misconceptionId          String
  rank                    Int
  confidenceBand          String
  supportingEvidenceJson  Json
  conflictingEvidenceJson Json
  verificationNeeded      Boolean
  createdAt               DateTime        @default(now())
  session                 LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  attempt                 LearnerAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  misconception           Misconception   @relation(fields: [misconceptionId], references: [id])

  @@index([sessionId, rank])
  @@index([misconceptionId])
}

model VerificationInteraction {
  id                   String             @id @default(cuid())
  sessionId            String
  questionTemplateId   String
  question             String
  response             String?
  status               VerificationStatus
  hypothesisBeforeJson Json
  hypothesisAfterJson  Json?
  createdAt            DateTime           @default(now())
  answeredAt           DateTime?
  session              LearningSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([questionTemplateId])
}

model Intervention {
  id                    String          @id @default(cuid())
  sessionId             String
  misconceptionId        String
  interventionRecordId   String
  level                 Int
  type                  String
  contentJson           Json
  visualizerConfigJson  Json
  acknowledgedAt        DateTime?
  createdAt             DateTime        @default(now())
  session               LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  misconception          Misconception  @relation(fields: [misconceptionId], references: [id])

  @@index([sessionId, level])
  @@index([misconceptionId])
}

model TransferAttempt {
  id             String          @id @default(cuid())
  sessionId      String
  problemId      String
  answerJson     Json
  explanation    String
  supportUsed    Boolean
  success        Boolean
  evaluationJson Json
  submissionKey  String
  createdAt      DateTime        @default(now())
  session        LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problem        Problem         @relation(fields: [problemId], references: [id])

  @@unique([sessionId, submissionKey])
  @@index([sessionId])
}

model ReasoningDeltaReport {
  id                   String          @id @default(cuid())
  sessionId            String          @unique
  beforeJson           Json
  afterJson            Json
  dimensionsJson       Json
  learnerFacingSummary String
  remainingGapsJson    Json
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  session              LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SessionEvent {
  id          String          @id @default(cuid())
  sessionId   String
  eventType   String
  fromStage   LearningStage?
  toStage     LearningStage?
  payloadJson Json
  createdAt   DateTime        @default(now())
  session     LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([eventType])
}

model IdempotencyRecord {
  id           String   @id @default(cuid())
  key          String
  scope        String
  requestHash  String
  responseJson Json
  statusCode   Int
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([scope, key])
  @@index([expiresAt])
}
